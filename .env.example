# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lineageiq_dev

# ── Postgres (Debezium CDC source) ────────────────────────────────────────────
POSTGRES_DSN=postgresql://lineageiq:lineageiq_dev@postgres:5432/lineageiq

# ── Redis (Celery broker + blast radius cache) ────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Kafka / Schema Registry ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Blast Radius Cache ────────────────────────────────────────────────────────
BLAST_RADIUS_CACHE_TTL=900   # 15 minutes

# ── LLM Inference ─────────────────────────────────────────────────────────────
INFERENCE_MODEL=gpt-4o
TEXT2CYPHER_MODEL=gpt-4o
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0
